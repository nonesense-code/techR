<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Modify Product</title>
</head>
<body>
  <div class="p-4 text-black h-full w-full bg-zinc-700">
    <h1 class="text-4xl text-white text-center mb-6">Modify Product</h1>
    
    <% if (find) { %>
      <form method="post" action="/modify/<%= find.id %>" class="w-full max-w-lg mx-auto bg-sky-600 p-4 rounded-lg">
        <div class="flex flex-col gap-4">
          <select
            placeholder="noothinbg"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
          >
            <option value="phone" <%= find.productType === 'phone' ? 'selected' : '' %>>Phone</option>
            <option value="laptop" <%= find.productType === 'laptop' ? 'selected' : '' %>>Laptop</option>
            <option value="tablet" <%= find.productType === 'tablet' ? 'selected' : '' %>>Tablet</option>
          </select>
          <select
            name="popularity"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
          >
            <option value="popular" <%= find.popularity === 'popular' ? 'selected' : '' %>>Popular</option>
            <option value="average" <%= find.popularity === 'average' ? 'selected' : '' %>>Average</option>
            <option value="not_pop" <%= find.popularity === 'not_pop' ? 'selected' : '' %>>Not Popular</option>
          </select>

          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product Name"
            name="name"
            value="<%= find.name %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Dimension"
            name="dimension"
            value="<%= find.dimension %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Build"
            name="build"
            value="<%= find.build %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Weight"
            name="weight"
            value="<%= find.weight %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Display Type"
            name="dtype"
            value="<%= find.dtype %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Display Size"
            name="size"
            value="<%= find.size%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Display Resolution"
            name="resolution"
            value="<%= find.resolution %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Operation System"
            name="os"
            value="<%= find.os %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product Processor"
            name="processor"
            value="<%= find.processor%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product RAM"
            name="memory"
            value="<%= find.memory%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product Storage"
            name="storage"
            value="<%= find.storage%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product Graphics Card"
            name="graphics"
            value="<%= find.graphics%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Battery Capacity"
            name="capacity"
            value="<%= find.capacity%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Battery Charging"
            name="charging"
            value="<%= find.charging %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Wi-Fi"
            name="wifi"
            value="<%= find.wifi %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Bluetooth"
            name="bluetooth"
            value="<%= find.bluetooth %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="USB Type C"
            name="typec"
            value="<%= find.typec%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="USB Type A"
            name="usba"
            value="<%= find.usba %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Ethernet"
            name="ethernet"
            value="<%= find.ethernet %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="HDMI"
            name="hdmi"
            value="<%= find.hdmi %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Audio Jack"
            name="audiojack"
            value="<%= find.audiojack %>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product Main-Camera"
            name="maincamera"
            value="<%= find.maincamera%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product Front-Camera"
            name="frontcamera"
            value="<%= find.frontcamera%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product Video"
            name="video"
            value="<%= find.video%>"
          />
          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product Price"
            name="price"
            value="<%= find.price%>"
          />

          <input
            type="text"
            class="outline-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold"
            placeholder="Product Image URL"
            name="image"
            value="<%= find.image %>"
          />

          

          <textarea
            name="blog"
            class="outline-none resize-none rounded-lg bg-zinc-500 text-white px-2 py-1 placeholder:text-zinc-300/80 placeholder:font-semibold h-52"
            placeholder="Blog"
          ><%= find.blog %></textarea>

          <div class="flex gap-2 items-center justify-center">
            <input
              type="submit"
              value="Update"
              class="bg-orange-600 p-2 rounded-xl font-semibold text-lg outline-none"
            />
            <input
              type="reset"
              value="Reset"
              class="bg-orange-600 p-2 rounded-xl font-semibold text-lg outline-none"
            />
          </div>
        </div>
      </form>
    <% } else { %>
      <p class="text-white text-center">Product not found.</p>
    <% } %>
  </div>
</body>
</html>
