<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script src="https://cdn.tailwindcss.com"></script>
  <title>Modify Product</title>
</head>
<body class="bg-zinc-700 text-black">
  <div class="p-4 min-h-screen flex flex-col items-center">
    <h1 class="text-4xl text-white mb-6">Modify Product</h1>
    
    <% if (find) { %>
      <form method="post" action="/modify/<%= find.id %>" class="w-full max-w-4xl bg-sky-600 p-6 rounded-lg shadow-lg">
        <div class="space-y-4">
          <!-- Product Type Select -->
          <div class="flex flex-col md:flex-row md:space-x-4">
            <select
              name="productType"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold w-full md:w-1/3"
            >
              <option value="phone" <%= find.productType === 'phone' ? 'selected' : '' %>>Phone</option>
              <option value="laptop" <%= find.productType === 'laptop' ? 'selected' : '' %>>Laptop</option>
              <option value="tablet" <%= find.productType === 'tablet' ? 'selected' : '' %>>Tablet</option>
            </select>

            <select
              name="popularity"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold w-full md:w-1/3"
            >
              <option value="popular" <%= find.popularity === 'popular' ? 'selected' : '' %>>Popular</option>
              <option value="average" <%= find.popularity === 'average' ? 'selected' : '' %>>Average</option>
              <option value="not_pop" <%= find.popularity === 'not_pop' ? 'selected' : '' %>>Not Popular</option>
            </select>
          </div>

          <!-- General Product Details -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input
              type="text"
              name="name"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Product Name"
              value="<%= find.name %>"
            />
            <input
              type="text"
              name="dimension"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Dimension"
              value="<%= find.dimension %>"
            />
            <input
              type="text"
              name="build"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Build"
              value="<%= find.build %>"
            />
            <input
              type="text"
              name="weight"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Weight"
              value="<%= find.weight %>"
            />
            <input
              type="text"
              name="dtype"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Display Type"
              value="<%= find.dtype %>"
            />
            <input
              type="text"
              name="size"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Display Size"
              value="<%= find.size %>"
            />
            <input
              type="text"
              name="resolution"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Display Resolution"
              value="<%= find.resolution %>"
            />
            <input
              type="text"
              name="os"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Operation System"
              value="<%= find.os %>"
            />
            <input
              type="text"
              name="processor"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Product Processor"
              value="<%= find.processor %>"
            />

            <!-- RAM Fields -->
            <div class="flex flex-col space-y-2">
              <label class="text-white font-semibold">RAM:</label>
              <input
                type="text"
                name="ram1"
                class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
                placeholder="RAM 1"
                value="<%= find.ram1 %>"
              />
              <input
                type="text"
                name="ram2"
                class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
                placeholder="RAM 2"
                value="<%= find.ram2 %>"
              />
              <input
                type="text"
                name="ram3"
                class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
                placeholder="RAM 3"
                value="<%= find.ram3 %>"
              />
            </div>

            <!-- Storage Fields -->
            <div class="flex flex-col space-y-2">
              <label class="text-white font-semibold">Storage:</label>
              <input
                type="text"
                name="storage1"
                class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
                placeholder="Storage 1"
                value="<%= find.storage1 %>"
              />
              <input
                type="text"
                name="storage2"
                class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
                placeholder="Storage 2"
                value="<%= find.storage2 %>"
              />
              <input
                type="text"
                name="storage3"
                class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
                placeholder="Storage 3"
                value="<%= find.storage3 %>"
              />
            </div>

            <!-- Price Fields -->
            <div class="flex flex-col space-y-2">
              <label class="text-white font-semibold">Price:</label>
              <input
                type="text"
                name="price1"
                class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
                placeholder="Price 1"
                value="<%= find.price1 %>"
              />
              <input
                type="text"
                name="price2"
                class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
                placeholder="Price 2"
                value="<%= find.price2 %>"
              />
              <input
                type="text"
                name="price3"
                class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
                placeholder="Price 3"
                value="<%= find.price3 %>"
              />
            </div>

            <!-- Additional Fields -->
            <input
              type="text"
              name="graphics"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Product Graphics Card"
              value="<%= find.graphics %>"
            />
            <input
              type="text"
              name="capacity"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Battery Capacity"
              value="<%= find.capacity %>"
            />
            <input
              type="text"
              name="charging"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Battery Charging"
              value="<%= find.charging %>"
            />
            <input
              type="text"
              name="wifi"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Wi-Fi"
              value="<%= find.wifi %>"
            />
            <input
              type="text"
              name="bluetooth"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Bluetooth"
              value="<%= find.bluetooth %>"
            />
            <input
              type="text"
              name="typec"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="USB Type C"
              value="<%= find.typec %>"
            />
            <input
              type="text"
              name="usba"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="USB Type A"
              value="<%= find.usba %>"
            />
            <input
              type="text"
              name="ethernet"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Ethernet"
              value="<%= find.ethernet %>"
            />
            <input
              type="text"
              name="hdmi"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="HDMI"
              value="<%= find.hdmi %>"
            />
            <input
              type="text"
              name="audiojack"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Audio Jack"
              value="<%= find.audiojack %>"
            />
            <input
              type="text"
              name="maincamera"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Main Camera"
              value="<%= find.maincamera %>"
            />
            <input
              type="text"
              name="frontcamera"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Front Camera"
              value="<%= find.frontcamera %>"
            />
            <input
              type="text"
              name="video"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Video"
              value="<%= find.video %>"
            />
            <input
              type="text"
              name="image"
              class="outline-none rounded-lg bg-zinc-500 text-white px-3 py-2 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Image URL"
              value="<%= find.image %>"
            />
          </div>

          <!-- Blog Text Area -->
          <div>
            <label class="block text-white font-semibold mb-1 text-lg">Blog:</label>
            <textarea
              name="blog"
              class="w-full outline-none resize-none rounded-lg bg-zinc-500 text-white px-3 py-2 h-40 placeholder:text-zinc-300/80 placeholder:font-semibold"
              placeholder="Blog"
            ><%= find.blog %></textarea>
          </div>

          <!-- Submit and Reset Buttons -->
          <div class="flex gap-4 justify-center mt-6">
            <input
              type="submit"
              value="Update"
              class="bg-orange-600 p-3 rounded-lg font-semibold text-lg cursor-pointer hover:bg-orange-700 transition"
            />
            <input
              type="reset"
              value="Reset"
              class="bg-orange-600 p-3 rounded-lg font-semibold text-lg cursor-pointer hover:bg-orange-700 transition"
            />
          </div>
        </div>
      </form>
    <% } else { %>
      <p class="text-center text-lg text-white">Product not found.</p>
    <% } %>
  </div>
</body>
</html>
